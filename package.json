{
  "name": "@rbenzi/nest-domain-inject",
  "version": "0.1.3",
  "description": "NestJS domain injection library with context-based decorators",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benzispawn/nest-domain-inject.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:watch": "jest --config jest.config.cjs --watch",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/testing": "^11.1.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
